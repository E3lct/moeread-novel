<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>墨读 Moeread</display-name>

    <!-- 字符编码过滤器：所有请求统一 UTF-8，解决中文乱码 -->
    <filter>
        <filter-name>EncodingFilter</filter-name>
        <filter-class>com.moeread.util.EncodingFilter</filter-class>
        <init-param>
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- 登录拦截器：未登录用户跳转到登录页 -->
    <filter>
        <filter-name>LoginFilter</filter-name>
        <filter-class>com.moeread.util.LoginFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>LoginFilter</filter-name>
        <url-pattern>/home</url-pattern>
        <url-pattern>/book</url-pattern>
        <url-pattern>/reader</url-pattern>
        <url-pattern>/stats</url-pattern>
        <url-pattern>/settings</url-pattern>
        <url-pattern>/import</url-pattern>
    </filter-mapping>

    <!-- 欢迎页：访问根路径时由 index.jsp 做重定向 -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- 错误页配置 -->
    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/jsp/error/404.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/WEB-INF/jsp/error/500.jsp</location>
    </error-page>

    <!-- Session 超时：30 分钟 -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>
</web-app>
